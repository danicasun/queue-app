# Copy to .env.local and fill in values from:
# Supabase → Project Settings → API (URL + anon key)
# Supabase → Project Settings → Database → Connection string (for schema script only)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used for auth redirects when the request has no Origin (e.g. some server contexts).
# In production, set this to your public site URL, e.g. https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Postgres connection URI for ./scripts/apply-schema.sh only (not used by Next.js at runtime).
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or use the direct connection string from the dashboard if you prefer.
SUPABASE_DB_URL=
